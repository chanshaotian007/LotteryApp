page {
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 100%);
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.button-row button {
  flex: 1;
}

.result-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.number-chip {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  background: #dc2626;
  color: #fff;
  font-size: 24rpx;
}

.number-chip.secondary {
  background: #2563eb;
}
