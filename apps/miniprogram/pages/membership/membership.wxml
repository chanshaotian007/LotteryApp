<view class="page">
  <view class="card">
    <view class="title">会员状态</view>
    <view class="muted">当前状态：{{membership.status || 'unknown'}}</view>
    <view class="muted">到期时间：{{membership.expiresAt || '未开通'}}</view>
  </view>
  <view class="card">
    <view class="section-title">会员产品</view>
    <view wx:for="{{products}}" wx:key="id" class="result-item">
      <view>{{item.name}}</view>
      <view class="muted">{{item.priceFen}} 分 / {{item.durationDays}} 天</view>
      <button size="mini" type="primary" data-code="{{item.code}}" bindtap="onBuy">立即购买</button>
    </view>
  </view>
</view>
