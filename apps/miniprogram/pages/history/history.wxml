<view class="page">
  <view class="card">
    <view class="title">最近开奖</view>
    <view wx:for="{{draws}}" wx:key="issue" class="result-item">
      <view>{{item.issue}}</view>
      <view>
        <text wx:for="{{item.primaryNumbers}}" wx:key="*this" class="number-chip">{{item}}</text>
        <text wx:for="{{item.secondaryNumbers}}" wx:key="*this" class="number-chip secondary">{{item}}</text>
      </view>
      <view class="muted">{{item.drawDate}}</view>
    </view>
  </view>
</view>
