{
  "name": "@lottery/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
