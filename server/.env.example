LOTTERY_APP_ENV=development
LOTTERY_DATABASE_URL=postgresql+psycopg://lottery:lottery@postgres:5432/lottery
LOTTERY_REDIS_URL=redis://redis:6379/0
LOTTERY_ADMIN_TOKEN=replace-with-a-long-random-admin-token
LOTTERY_DEMO_MEMBER_TOKEN=replace-with-member-token-or-jwt-validation
LOTTERY_AUTO_CREATE_TABLES=false
LOTTERY_GENERATE_RATE_LIMIT_PER_MINUTE=60
LOTTERY_GOOGLE_PLAY_PACKAGE_NAME=com.lottery.app
LOTTERY_GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=
LOTTERY_PREMIUM_PRODUCT_IDS=lottery_premium_monthly,lottery_premium_yearly
