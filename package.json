{
  "name": "lotteryapp-monorepo",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run packages/domain/test packages/adapters/test services/api/test",
    "dev:api": "pnpm --filter @lottery/api dev",
    "dev:admin": "pnpm --filter @lottery/admin-web dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
